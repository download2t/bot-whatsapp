ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Data Source=app.db
Cors__AllowedOrigins__0=http://localhost:5173
Jwt__Issuer=ApiBotWhatsapp
Jwt__Audience=ApiBotWhatsappClient
Jwt__ExpiresMinutes=120
Jwt__SigningKey=CHANGE_THIS_TO_A_MINIMUM_32_BYTE_HS256_KEY
WhatsApp__BridgeBaseUrl=http://localhost:3000
WhatsApp__TimeZoneId=E. South America Standard Time
WhatsApp__WebhookToken=CHANGE_THIS_WEBHOOK_TOKEN
